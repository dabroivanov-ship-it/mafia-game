# Copy to server/.env on the VPS (never commit server/.env)
NODE_ENV=production
PORT=3001

# Required — min 32 random characters (openssl rand -hex 32)
JWT_SECRET=

# Comma-separated admin usernames (promoted on server start if account exists)
ADMIN_USERNAMES=admin

# Required in production — your public site URL (no trailing slash)
CORS_ORIGIN=https://your-domain.example

# Optional: Telegram bot token for Web App and /start handler
# TELEGRAM_BOT_TOKEN=1234567890:AA...
# TELEGRAM_WEBAPP_URL=https://your-domain.example

# Telegram OIDC login (BotFather → Bot Settings → Web Login → OpenID Connect)
# TELEGRAM_OIDC_CLIENT_ID=1234567890
# TELEGRAM_OIDC_CLIENT_SECRET=your-client-secret-from-botfather

# Local dev only: skip JWT/CORS hard checks (never use on VPS)
# ALLOW_INSECURE_DEV=1

# Optional overrides (defaults: server/data/mafia.db, server/uploads/avatars)
# DB_PATH=/home/mafia-game/server/data/mafia.db
# UPLOADS_DIR=/home/mafia-game/server/uploads/avatars
