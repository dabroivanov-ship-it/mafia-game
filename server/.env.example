# Copy to server/.env on the VPS (never commit server/.env)
NODE_ENV=production
PORT=3001

# Required in production — min 32 random characters
JWT_SECRET=

# Comma-separated admin usernames (must already be registered)
ADMIN_USERNAMES=admin

# Optional: enable Telegram login widget verification
# TELEGRAM_BOT_TOKEN=1234567890:AA...

# Optional overrides (defaults: server/data/mafia.db, server/uploads/avatars)
# DB_PATH=/home/mafia-game/server/data/mafia.db
# UPLOADS_DIR=/home/mafia-game/server/uploads/avatars

# Optional: restrict browser API origin in production (e.g. https://24vpsbro.ru)
# CORS_ORIGIN=https://24vpsbro.ru
